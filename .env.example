GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
JWT_SECRET=replace-with-a-long-random-secret
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
# Optional ML workflow gate. Defaults to true outside production and false in production.
# ENABLE_ML_WORKFLOW=true
# For production on Azure App Service, prefer:
# GOOGLE_REDIRECT_URI=https://cloaksgambit.azurewebsites.net/api/auth/google/callback
# AUTH_COOKIE_SAME_SITE=none
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_DOMAIN=.your-custom-domain.com
COSMOSDB_CONNECTION_STRING=mongodb://localhost:27017/cloaks-gambit
MONGODB_ATLAS_CONNECTION_STRING=mongodb+srv://user:password@cluster.mongodb.net/cloaksgambit?retryWrites=true&w=majority

